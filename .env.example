# Database
# Docker Compose maps Postgres to host port 5433 (avoids conflict with local Postgres on 5432)
DATABASE_URL=postgresql+asyncpg://recruiter:recruiter@localhost:5433/recruiter_ranking
DATABASE_URL_SYNC=postgresql://recruiter:recruiter@localhost:5433/recruiter_ranking

# Redis
REDIS_URL=redis://localhost:6379/0

# Groq LLM
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# App
APP_ENV=development
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
CORS_ORIGINS=http://localhost:3000

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# Pipeline
RETRIEVAL_TOP_K=200
RERANK_TOP_K=20
FINAL_TOP_K=10
